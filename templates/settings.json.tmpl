{
  "_comment": "PreToolUse Bash guard + permissions allow/deny. Loop runs Claude with --permission-mode auto so deny rules here ARE enforced; this hook also fires regardless of permission mode as defense in depth. See scripts/claude_bash_guard.py.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{ROOT_DIR}}/scripts/claude_bash_guard.py"
          }
        ]
      }
    ]
  }
}
