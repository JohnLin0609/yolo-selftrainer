#!/bin/bash
# Do NOT use set -e — we need to catch training failures and still wake Claude

# Activate venv (has ultralytics + torch installed)
source {{VENV_PATH}}/bin/activate

# Verify ultralytics version
python -c "import ultralytics; v=ultralytics.__version__; assert v.startswith('8.'), f'Expected ultralytics 8.x, got {v}'"

DATASET="{{DATASET_YAML}}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
FRAMEWORK_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
EVENT="python3 $FRAMEWORK_ROOT/scripts/event.py $SCRIPT_DIR"

# Read round counter (cached view of events.jsonl — see scripts/event.py).
# Defaults to 0 if cache is missing; events.jsonl is the source of truth.
ROUND=$(cat "$SCRIPT_DIR/round_counter" 2>/dev/null || echo 0)
case "$ROUND" in ''|*[!0-9]*) ROUND=0 ;; esac
# MAX_ROUNDS lets the post-hoc test-eval hook decide whether to fire on every
# round or only the last one. Kept in sync with start_*.sh by the scaffold.
MAX_ROUNDS={{MAX_ROUNDS}}

# Parameters — edit these each cycle using sed
WEIGHTS=${1:-"{{MODELS_DIR}}/{{PRIMARY_MODEL}}"}
EPOCHS=100
LR=0.01
LR_FINAL=0.01
BATCH=-1
IMGSZ={{IMGSZ}}
PATIENCE=50
# AdamW explicit — optimizer=auto overrides lr0 in ultralytics 8.4.x
OPTIMIZER="AdamW"
MOMENTUM=0.937
WEIGHT_DECAY=0.0005
WARMUP_EPOCHS=3.0
WARMUP_MOMENTUM=0.8
COS_LR=false
HSV_H=0.015
HSV_S=0.7
HSV_V=0.4
DEGREES={{DEGREES}}
TRANSLATE=0.1
SCALE={{SCALE}}
FLIPLR={{FLIPLR}}
FLIPUD={{FLIPUD}}
MOSAIC={{MOSAIC}}
MIXUP={{MIXUP}}
COPY_PASTE={{COPY_PASTE}}
ERASING={{ERASING}}
CLOSE_MOSAIC=10

# ─── Parameter boundary (Harness §5.1 trust boundary) ────────────────
# The agent's contract: write a flat JSON dict to next_params.json. It does
# NOT edit train.sh. apply_params.py is the SOLE writer of effective_params.env
# (the file sourced below), and reads the bounds from scripts/param_bounds.py
# — the single source of truth shared with baseline_policy.py.
#
# On any validation failure apply_params emits a validation-failed event and
# writes next_instruction.md telling the agent which key to fix. train.sh
# only needs to handle the consecutive_failures counter + HALTED logic here.
echo "[apply-params] validating next_params.json → effective_params.env"
python3 "$FRAMEWORK_ROOT/scripts/apply_params.py" \
    --project     "$SCRIPT_DIR" \
    --task        "{{TASK}}" \
    --round       "$ROUND" \
    --next-params "$SCRIPT_DIR/next_params.json" \
    --out         "$SCRIPT_DIR/effective_params.env"
VALIDATE_EXIT=$?

if [ "$VALIDATE_EXIT" -ne 0 ]; then
  echo "[train] ABORT: apply_params rejected next_params.json. Not launching." >&2
  # apply_params has already (a) emitted the validation-failed event with
  # the structured violations payload and (b) written next_instruction.md
  # with the per-key fix-this guidance. We only handle the failure counter
  # + HALTED check here. Round NOT consumed (no train_completed touched).
  FAILS=$(cat "$SCRIPT_DIR/consecutive_failures" 2>/dev/null || echo 0)
  FAILS=$((FAILS + 1))
  echo "$FAILS" > "$SCRIPT_DIR/consecutive_failures"
  if [ "$FAILS" -ge 3 ]; then
    cat > "$SCRIPT_DIR/HALTED" <<HALT_EOF
HALTED at $(date '+%Y-%m-%d %H:%M:%S') after $FAILS consecutive failures.
Last failure: parameter validation (no training run launched).

To resume: ensure next_params.json is valid, then:
  rm $SCRIPT_DIR/HALTED $SCRIPT_DIR/consecutive_failures
  bash $SCRIPT_DIR/start_*.sh
HALT_EOF
    echo "[train] CIRCUIT BREAKER TRIPPED — $FAILS consecutive failures. Wrote HALTED." >&2
    $EVENT emit halted --reason circuit-breaker-validation \
      --details-json "{\"consecutive_failures\": $FAILS}" || true
    exit 1
  fi
  echo "[train] Waking the agent to fix params (failure $FAILS/3)..." >&2
  # Order matters: only one start_*.sh exists per project; pick the most
  # specific. start_baseline.sh skips the LLM entirely; agent uses run_agent.py;
  # claude is the original CLI flow.
  if [ -f "$SCRIPT_DIR/start_baseline.sh" ]; then
    bash "$SCRIPT_DIR/start_baseline.sh"
  elif [ -f "$SCRIPT_DIR/start_agent.sh" ]; then
    bash "$SCRIPT_DIR/start_agent.sh"
  else
    bash "$SCRIPT_DIR/start_claude.sh"
  fi
  exit 1
fi

# ─── Source the validated overrides ──────────────────────────────────
# effective_params.env was written by apply_params.py above. It overrides
# the scaffolded defaults at the top of this file with only the keys the
# agent set in next_params.json. Missing keys keep their scaffolded values.
# On round 1 cold start the file is empty (no agent picks yet).
if [ -s "$SCRIPT_DIR/effective_params.env" ]; then
  set -a
  # shellcheck disable=SC1091
  source "$SCRIPT_DIR/effective_params.env"
  set +a
fi

# ─── Defense-in-depth: re-validate via the same bounds source ────────
# apply_params is the primary boundary; this CLI call catches the case
# where it was bypassed (manual launch, broken script, future bug).
# In normal operation this exits 0 — apply_params already enforced the
# same bounds upstream. Failure here means the bounds source-of-truth
# disagrees with the effective state, which is operator-investigate territory.
if ! python3 "$FRAMEWORK_ROOT/scripts/param_bounds.py" validate-env \
        --task "{{TASK}}" --weights "$WEIGHTS" 1>&2; then
  echo "[train] FATAL: defense-in-depth param check failed AFTER apply_params succeeded." >&2
  echo "[train] effective_params.env was tampered with, or apply_params/param_bounds disagree." >&2
  $EVENT emit halted --reason defense-in-depth-validator \
    --details-json '{"see":"current.log"}' || true
  cat > "$SCRIPT_DIR/HALTED" <<DID_HALT_EOF
HALTED at $(date '+%Y-%m-%d %H:%M:%S') — defense-in-depth validator caught
a discrepancy between apply_params.py and scripts/param_bounds.py.

In normal operation these agree; failure here is an operator concern, not
something the agent can fix. Most likely causes:
  - effective_params.env was edited by hand between apply_params and yolo
  - param_bounds.py was updated to tighter bounds and apply_params still
    used the older copy (cache or import issue)

Inspect:
  cat $SCRIPT_DIR/effective_params.env
  python3 $FRAMEWORK_ROOT/scripts/param_bounds.py validate-env --task {{TASK}} --weights "$WEIGHTS"
DID_HALT_EOF
  exit 1
fi

# ─── Generate run name: YYYYMMDD_HHMMSS_claude_MODEL ────────────────
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
# Extract model short name from weights path (e.g., yolo11n-obb.pt → v11, yolov8n-obb.pt → v8)
if echo "$WEIGHTS" | grep -q "best.pt"; then
  # Fine-tuning from a previous run's best.pt — try to extract model from parent dir name
  PARENT_DIR=$(basename "$(dirname "$(dirname "$WEIGHTS")")")
  MODEL_SHORT=$(echo "$PARENT_DIR" | grep -oE 'v[0-9]+' | head -1)
  MODEL_SHORT="${MODEL_SHORT:-ft}_ft"
else
  MODEL_SHORT=$(basename "$WEIGHTS" | sed -E 's/.*yolo[v]?([0-9]+).*/v\1/')
fi
RUN_NAME="${TIMESTAMP}_claude_${MODEL_SHORT}"

# Write run name immediately so start_claude.sh can find it for logging
echo "$RUN_NAME" > "$SCRIPT_DIR/last_run_name"

echo "[train] Run: $RUN_NAME | weights: $WEIGHTS | lr: $LR | epochs: $EPOCHS"

# Event: training started (audit trail — events.jsonl is Harness §九 source of truth).
# `|| true` because emit failure must NOT abort the training run itself.
$EVENT emit training-started --round "$ROUND" --run-name "$RUN_NAME" \
  --params-json "$(python3 -c "
import json
print(json.dumps({
  'weights': '$WEIGHTS', 'epochs': $EPOCHS, 'lr': $LR, 'lr_final': $LR_FINAL,
  'batch': '$BATCH', 'imgsz': $IMGSZ, 'patience': $PATIENCE,
  'optimizer': '$OPTIMIZER', 'mosaic': $MOSAIC, 'mixup': $MIXUP,
  'degrees': $DEGREES, 'erasing': $ERASING, 'weight_decay': $WEIGHT_DECAY,
}))
")" || true

TRAIN_START_TS=$SECONDS

yolo {{TASK}} train \
  data="$DATASET" \
  model="$WEIGHTS" \
  epochs="$EPOCHS" \
  lr0="$LR" \
  lrf="$LR_FINAL" \
  batch="$BATCH" \
  imgsz="$IMGSZ" \
  patience="$PATIENCE" \
  optimizer="$OPTIMIZER" \
  momentum="$MOMENTUM" \
  weight_decay="$WEIGHT_DECAY" \
  warmup_epochs="$WARMUP_EPOCHS" \
  warmup_momentum="$WARMUP_MOMENTUM" \
  cos_lr="$COS_LR" \
  hsv_h="$HSV_H" \
  hsv_s="$HSV_S" \
  hsv_v="$HSV_V" \
  degrees="$DEGREES" \
  translate="$TRANSLATE" \
  scale="$SCALE" \
  fliplr="$FLIPLR" \
  flipud="$FLIPUD" \
  mosaic="$MOSAIC" \
  mixup="$MIXUP" \
  copy_paste="$COPY_PASTE" \
  erasing="$ERASING" \
  close_mosaic="$CLOSE_MOSAIC" \
  project="{{RUNS_DIR}}/{{TASK}}" \
  name="$RUN_NAME" \
  exist_ok=false \
  amp=true \
  device={{DEVICE}} \
  workers=8

TRAIN_EXIT=$?
TRAIN_DURATION=$((SECONDS - TRAIN_START_TS))

# Event: training finished. Emit before any decision logic so a crash in the
# circuit-breaker code below doesn't lose the audit record.
$EVENT emit training-finished --round "$ROUND" --run-name "$RUN_NAME" \
  --exit-code "$TRAIN_EXIT" --duration-sec "$TRAIN_DURATION" || true

# ─── Circuit breaker (Harness §6.4.5) ────────────────────────────────
# Reset the counter on success so a clean run wipes prior failures.
# On crash, bump the counter; if we hit 3 consecutive failures we write HALTED
# and refuse to wake Claude. start_claude.sh checks HALTED at the top so the
# loop dies cleanly instead of burning GPU on a broken setup.
if [ $TRAIN_EXIT -eq 0 ]; then
  echo "[train] Done: $RUN_NAME"
  echo "0" > "$SCRIPT_DIR/consecutive_failures"
  # Read results.csv and emit a training_metrics event for P3/P5 consumers.
  $EVENT extract-metrics --run-dir "{{RUNS_DIR}}/{{TASK}}/$RUN_NAME" \
    --task "{{TASK}}" --round "$ROUND" --run-name "$RUN_NAME" || true

  # Per-class diagnostics — re-run val() on best.pt, emit a per_class_metrics
  # event with per-class P/R/mAP + the confusion matrix. Consumed by
  # build_prompt.py (worst-classes summary in the next prompt) and by
  # generate_report.py (Per-class weaknesses section). Failure here is
  # non-fatal — diagnostic enrichment, not a trust boundary.
  python3 "$FRAMEWORK_ROOT/scripts/per_class_metrics.py" extract \
    --project   "$SCRIPT_DIR" \
    --run-dir   "{{RUNS_DIR}}/{{TASK}}/$RUN_NAME" \
    --data-yaml "$DATASET" \
    --task      "{{TASK}}" \
    --round     "$ROUND" \
    --run-name  "$RUN_NAME" \
    || echo "[per-class] WARNING: extraction failed; continuing chain"

  # ─── Post-hoc test eval on held-out split (AGENT-INVISIBLE) ──────────
  # The resulting test_metrics event is firewalled from every prompt
  # path by build_prompt.py (AGENT_INVISIBLE_EVENT_TYPES). Operator-only
  # signal — never feeds back into the agent's tuning loop.
  #
  # Cadence:
  #   YOLO_TRAINER_TEST_EVAL=every  (default) — every successful round
  #   YOLO_TRAINER_TEST_EVAL=last             — only the final round
  #   YOLO_TRAINER_TEST_EVAL=off              — never
  # Failure is tolerated: a broken test eval prints a warning but does NOT
  # halt the chain, since it's post-hoc reporting, not a trust-boundary.
  if grep -qE "^\s*test:" "$DATASET"; then
    CADENCE="${YOLO_TRAINER_TEST_EVAL:-every}"
    case "$CADENCE" in
      every) DO_TEST=true ;;
      last)
        if [ "$ROUND" -ge "$MAX_ROUNDS" ]; then DO_TEST=true; else DO_TEST=false; fi
        ;;
      off|*)  DO_TEST=false ;;
    esac
    if [ "$DO_TEST" = true ]; then
      echo "[test-eval] evaluating best.pt on held-out test split"
      python3 "$FRAMEWORK_ROOT/scripts/run_test_eval.py" \
        --project "$SCRIPT_DIR" \
        --best-pt "{{RUNS_DIR}}/{{TASK}}/$RUN_NAME/weights/best.pt" \
        --data "$DATASET" \
        --task "{{TASK}}" \
        --round "$ROUND" \
        --run-name "$RUN_NAME" \
        || echo "[test-eval] WARNING: failed; continuing chain"
    fi
  fi

  # ─── Plateau circuit (independent of crash circuit breaker) ──────────
  # Reads training_metrics history (q_plateau_status in event.py) to detect
  # "primary metric stopped moving". Two outcomes:
  #   action=emit-warn → emit a plateau-detected event so build_prompt.py
  #                      injects an orthogonal-strategy nudge next round
  #   action=halt      → grace rounds exhausted; write HALTED and emit
  #                      halted --reason plateau so the chain stops cleanly
  # Overrides via env: YOLO_TRAINER_PLATEAU_N / _THRESHOLD / _M.
  PLATEAU_JSON=$($EVENT query plateau-status 2>/dev/null)
  if [ -n "$PLATEAU_JSON" ]; then
    PLATEAU_ACTION=$(printf '%s' "$PLATEAU_JSON" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("action",""))' 2>/dev/null)
    case "$PLATEAU_ACTION" in
      emit-warn)
        echo "[plateau] WARN: improvement under threshold — emitting plateau-detected"
        # Pull every numeric field once; pass each as a flag to event.py emit.
        eval "$(printf '%s' "$PLATEAU_JSON" | python3 -c '
import json, sys, shlex
d = json.load(sys.stdin)
for k in ("n","threshold","improvement","best_recent","best_before"):
    v = d.get(k)
    if v is None:
        v = 0
    print(f"PLATEAU_{k.upper()}={shlex.quote(str(v))}")')"
        $EVENT emit plateau-detected --round "$ROUND" \
          --n "$PLATEAU_N" --threshold "$PLATEAU_THRESHOLD" \
          --improvement "$PLATEAU_IMPROVEMENT" \
          --best-recent "$PLATEAU_BEST_RECENT" \
          --best-before "$PLATEAU_BEST_BEFORE" \
          || true
        ;;
      halt)
        PLATEAU_M_USED=${YOLO_TRAINER_PLATEAU_M:-2}
        echo "[plateau] HALT: $PLATEAU_M_USED grace rounds passed without improvement above threshold"
        cat > "$SCRIPT_DIR/HALTED" <<PLATEAU_HALT_EOF
HALTED at $(date '+%Y-%m-%d %H:%M:%S') — plateau circuit tripped.

A plateau-detected event was emitted in an earlier round; \$YOLO_TRAINER_PLATEAU_M
($PLATEAU_M_USED) grace rounds since then produced no improvement above
threshold (YOLO_TRAINER_PLATEAU_THRESHOLD). This is NOT a crash — the agent
exhausted the current direction without breaking through.

Inspect the trajectory:
  python3 $FRAMEWORK_ROOT/scripts/event.py $SCRIPT_DIR query metrics-table
  python3 $FRAMEWORK_ROOT/scripts/event.py $SCRIPT_DIR query plateau-status

Next step is operator judgement, not a fix-and-retry:
  - collect more / cleaner data
  - change the model architecture
  - widen YOLO_TRAINER_PLATEAU_THRESHOLD if the noise floor is the issue

To resume after deciding:
  rm $SCRIPT_DIR/HALTED
  bash $SCRIPT_DIR/start_*.sh
PLATEAU_HALT_EOF
        $EVENT emit halted --reason plateau \
          --details-json "$PLATEAU_JSON" || true
        touch "$SCRIPT_DIR/train_completed"
        rm -f "$SCRIPT_DIR/train.pid"
        exit 0
        ;;
    esac
  fi
else
  echo "[train] FAILED (exit code $TRAIN_EXIT) — diagnosing..." >&2
  PARAMS=$(grep -E '^(WEIGHTS|EPOCHS|LR|LR_FINAL|BATCH|IMGSZ|PATIENCE|OPTIMIZER|DATASET)=' "$SCRIPT_DIR/train.sh")
  if [ -z "$PARAMS" ]; then
    echo "[train] WARN: could not read params from train.sh" >&2
    PARAMS="(grep returned no matches; train.sh may be corrupted)"
  fi
  cat > "$SCRIPT_DIR/next_instruction.md" <<CRASH_EOF
## Training CRASHED

Run $RUN_NAME failed with exit code $TRAIN_EXIT.

## Diagnose
1. Check the log: tail -50 $SCRIPT_DIR/current.log
2. Look for: OOM, NaN, CUDA error, dataset error, missing file
3. Check if a partial run exists: ls -la {{RUNS_DIR}}/{{TASK}}/$RUN_NAME/
4. If OOM: reduce BATCH or IMGSZ in train.sh with sed
5. If other error: fix and relaunch
6. If unfixable: write STOP in next_instruction.md

## Previous params
$PARAMS

Rewrite next_instruction.md with full history before exiting.
CRASH_EOF
  FAILS=$(cat "$SCRIPT_DIR/consecutive_failures" 2>/dev/null)
  case "$FAILS" in ''|*[!0-9]*) FAILS=0 ;; esac
  FAILS=$((FAILS + 1))
  echo "$FAILS" > "$SCRIPT_DIR/consecutive_failures"
  if [ "$FAILS" -ge 3 ]; then
    cat > "$SCRIPT_DIR/HALTED" <<HALT_EOF
HALTED at $(date '+%Y-%m-%d %H:%M:%S') after $FAILS consecutive training failures.

Last failure: $RUN_NAME exited with code $TRAIN_EXIT.

Diagnose the root cause (do NOT just retry):
  tail -100 $SCRIPT_DIR/current.log
  cat $SCRIPT_DIR/next_instruction.md

To resume after fixing:
  rm $SCRIPT_DIR/HALTED $SCRIPT_DIR/consecutive_failures
  bash $SCRIPT_DIR/start_claude.sh
HALT_EOF
    echo "[train] CIRCUIT BREAKER TRIPPED — $FAILS consecutive failures. Wrote HALTED." >&2
    echo "[train] Not waking Claude. Inspect $SCRIPT_DIR/HALTED to resume." >&2
    $EVENT emit halted --reason circuit-breaker-train \
      --details-json "{\"consecutive_failures\": $FAILS, \"last_exit_code\": $TRAIN_EXIT}" || true
    touch "$SCRIPT_DIR/train_completed"  # consume the round so resume starts clean
    exit 1
  fi
  echo "[train] Failure $FAILS/3 — waking Claude to diagnose..." >&2
fi

# Clear train.pid before the recursive call. The current bash (train.sh) is
# the PID written here, and start_claude.sh will momentarily call Claude
# which checks "is training running?" by `kill -0 $(cat train.pid)`. Without
# clearing, that check returns "still alive" (our own wrapper bash) and
# round N+1 Claude exits without launching anything — chain breaks (P8 bug).
rm -f "$SCRIPT_DIR/train.pid"  # before recursive start_*.sh call
echo "[train] Waking the agent loop..."
touch "$SCRIPT_DIR/train_completed"
# Auto-detect mode: baseline mode scaffolds start_baseline.sh; agent mode
# scaffolds start_agent.sh; classic CLI mode only has start_claude.sh. The
# round-counter / events / circuit breaker are shared, so loop semantics
# match across modes — only the per-round "who picks params" step differs.
if [ -f "$SCRIPT_DIR/start_baseline.sh" ]; then
  bash "$SCRIPT_DIR/start_baseline.sh"
elif [ -f "$SCRIPT_DIR/start_agent.sh" ]; then
  bash "$SCRIPT_DIR/start_agent.sh"
else
  bash "$SCRIPT_DIR/start_claude.sh"
fi
