# Agent configuration (P6) — sourced by start_agent.sh at every wakeup.
#
# Set the LLM provider + model for this project's autonomous loop. Defaults
# come from `start_self_training.sh --provider X --model Y` at scaffold time;
# edit here to switch model between rounds.
#
# Provider catalog (anything LiteLLM supports works; common values listed):
#   anthropic    + claude-opus-4-7 / claude-sonnet-4-6 / claude-haiku-4-5
#   openai       + gpt-4o / gpt-4o-mini / o3
#   gemini       + gemini-2.5-pro / gemini-2.5-flash
#   groq         + llama-3.3-70b-versatile
#   together_ai  + Qwen/Qwen2.5-72B-Instruct-Turbo
#   ollama       + qwen2.5:32b / llama3.3:70b (must be running locally)
#   vllm         + <model-name>  (also set LLM_API_BASE)

LLM_PROVIDER="{{LLM_PROVIDER}}"
LLM_MODEL="{{LLM_MODEL}}"

# Optional: OpenAI-compatible endpoint for vLLM or other self-hosted servers.
# LLM_API_BASE="http://localhost:8000/v1"

# Optional knobs (defaults shown):
# LLM_MAX_TURNS=50            # ReAct hard limit per round
# LLM_TOOL_RESULT_MAX=30000   # truncate tool output above this many chars
# LLM_BASH_TIMEOUT=600        # seconds per bash command

# ─── API keys ────────────────────────────────────────────────────────
# Set the env var your provider needs. Examples — uncomment and fill in:
#   export ANTHROPIC_API_KEY="sk-ant-..."
#   export OPENAI_API_KEY="sk-..."
#   export GEMINI_API_KEY="AIza..."
#   export GROQ_API_KEY="gsk_..."
#   export TOGETHER_API_KEY="..."
#   # ollama runs locally; usually no key needed
#   # for vllm / openai-compatible servers, set OPENAI_API_KEY to anything
#   #   (e.g. "dummy") and LLM_API_BASE to the endpoint.
#
# Tip: keep keys in ~/.config/yolo_selftrainer/secrets.env and `source` it
# at the top of this file rather than committing the key to git.
